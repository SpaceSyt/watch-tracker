generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum EntryStatus {
  PLAN_TO_WATCH
  WATCHING
  COMPLETED
}

enum MediaType {
  MOVIE
  TV
  ANIME
}

model UserProfile {
  id         String           @id @default(cuid())
  authUserId String           @unique
  username   String?          @unique
  avatarUrl  String?
  entries    UserTitleEntry[]
  createdAt  DateTime         @default(now())
  updatedAt  DateTime         @updatedAt

  @@index([createdAt])
}

model Title {
  id             String           @id @default(cuid())
  externalSource String
  externalId     String
  title          String
  originalTitle  String?
  description    String?
  posterUrl      String?
  backdropUrl    String?
  mediaType      MediaType
  releaseDate    DateTime?
  totalEpisodes  Int?
  entries        UserTitleEntry[]
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  @@unique([externalSource, externalId])
  @@index([mediaType])
  @@index([releaseDate])
  @@index([createdAt])
}

model UserTitleEntry {
  id              String      @id @default(cuid())
  userId          String
  titleId         String
  status          EntryStatus
  rating          Int?
  review          String?
  progressCurrent Int?
  rewatchCount    Int         @default(0)
  startedAt       DateTime?
  finishedAt      DateTime?
  user            UserProfile @relation(fields: [userId], references: [id], onDelete: Cascade)
  title           Title       @relation(fields: [titleId], references: [id], onDelete: Cascade)
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  @@unique([userId, titleId])
  @@index([userId, status])
  @@index([userId, updatedAt])
  @@index([titleId])
}
